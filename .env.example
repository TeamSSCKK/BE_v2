# Copy this file to .env.local and fill in the values.
# Never commit .env.local.

# Supabase project URL. Do not append /rest/v1/.
SUPABASE_URL=https://oufchidafmrxgympbcqo.supabase.co

# Public client key. Keep the value on one line without quotes or a leading dot.
SUPABASE_ANON_KEY=

# Server-only key. Get it from Supabase Dashboard > Project Settings > API.
# Do not expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Naver Search Open API credentials. Server-only.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# ODsay API key.
# A URI key may be restricted to requests from registered browser origins.
ODSAY_API_KEY=

# Allowed frontend origins for local development.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

